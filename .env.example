## Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"

## App URL (used in password reset emails)
APP_URL="https://your-domain.tld"

## SMTP (for forgot password emails)
SMTP_HOST="smtp.timeweb.ru"
SMTP_PORT="465"
SMTP_USER="no-reply@your-domain.tld"
SMTP_PASS="your-smtp-password"
SMTP_FROM="BAR BOSS ONLINE <no-reply@your-domain.tld>"

# --- PostgreSQL (Timeweb Cloud) ---
# Use private network host/IP when possible.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"

# --- Firebase (existing auth / legacy storage) ---
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""

# Optional (admin scripts / API routes that use firebase-admin)
FIREBASE_SERVICE_ACCOUNT_KEY=""

